# ==============================================================================
# ZSH DEFAULTS & BEHAVIOR
# ==============================================================================

# History Configuration
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt append_history          # Append to history file instead of overwriting
setopt share_history           # Share history across multiple Zsh sessions
setopt hist_ignore_all_dups    # Remove older duplicate entries from history
setopt hist_reduce_blanks      # Remove superfluous blanks before recording entry
setopt HIST_IGNORE_SPACE       # Don't record entries starting with a space

# Keybindings
# bindkey -v                     # Enable vi mode for command line editing

# Autocompletion
autoload -Uz compinit
compinit -C

# ==============================================================================
# TOOLING & PATHS (Global)
# ==============================================================================

# Dedup path array
typeset -U path

# Define paths
path=(
    "$HOME/.local/bin"
    $path                     # Keep the default system paths at the end
)

# Export the uppercase variable for non-Zsh programs
export PATH


# Homebrew
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Node.js (fnm)
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
    export PATH="$FNM_PATH:$PATH"
    eval "$(fnm env)"
fi

# Editor configuration
if command -v code >/dev/null 2>&1; then
    export EDITOR="code --wait"
    export GIT_EDITOR="code --wait"
    export GITEDITOR="code --wait"
fi

# Antidote Plugin Manager (Checks for manual or Homebrew install)
if [[ -f "$HOME/.antidote/antidote.zsh" ]]; then
    source "$HOME/.antidote/antidote.zsh"
    antidote load
elif command -v brew &> /dev/null && [[ -f "$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh" ]]; then
    source "$(brew --prefix)/opt/antidote/share/antidote/antidote.zsh"
    antidote load
fi

# SSH Agent (Standard Linux/WSL)
ssh_pid=$(pgrep -u "$USER" ssh-agent)
if [ -z "$ssh_pid" ]; then
    ssh_env="$(ssh-agent -s)"
    echo "$ssh_env" | head -n 2 | tee ~/.ssh_agent_env >/dev/null
fi
if [ -f ~/.ssh_agent_env ]; then
    eval "$(cat ~/.ssh_agent_env)"
fi

# ==============================================================================
# PLATFORM-SPECIFIC OVERRIDES
# ==============================================================================

{{ if (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
    OMP_THEME_PATH="/mnt/c/Users/tyler/AppData/Local/Programs/oh-my-posh/themes"

    # if ! pgrep -f "wsl-ssh-pageant" >/dev/null; then
    #     $WSL_LOCALAPPDATA/Programs/WinSSH-Pageant/winssh-pageant.exe --socket "$SSH_AUTH_SOCK" &
    # fi
{{ else -}}
    OMP_THEME_PATH="$HOME/.config/oh-my-posh"
{{ end -}}

if command -v oh-my-posh &> /dev/null; then
    eval "$(oh-my-posh init zsh --config $OMP_THEME_PATH/hunk.omp.json)"
fi

# ==============================================================================
# ALIASES & HELPERS
# ==============================================================================

alias ls="ls --color=auto"
alias ll="ls -la"
alias c="clear"
alias e="${EDITOR:-vi}"

# Clipboard Support (WSL & Wayland/KDE Cosmic)
if [[ -n "$WAYLAND_DISPLAY" ]]; then
    alias pbcopy='wl-copy'
    alias pbpaste='wl-paste'
elif [[ -f /proc/version ]] && grep -qi microsoft /proc/version; then
    alias pbcopy='clip.exe'
fi
